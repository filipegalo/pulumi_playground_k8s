{
  "namespace": "litmus",
  "helm": {
    "values": {
      "mongodb": {
        "image": {
          "registry": "docker.io",
          "repository": "bitnami/mongodb",
          "tag": "latest"
        }
      },
      "portal": {
        "frontend": {
          "service": {
            "type": "NodePort"
          }
        },
        "server": {
          "graphqlServer": {
            "genericEnv": {
              "CHAOS_CENTER_UI_ENDPOINT": "http://chaos-litmus-frontend-service.litmus.svc.cluster.local:9091"
            }
          }
        }
      }
    }
  }
}
